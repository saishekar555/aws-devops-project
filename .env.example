# AWS DevOps Project - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ===== AWS Configuration =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_PROFILE=default

# ===== Terraform Configuration =====
TF_VAR_instance_type=t2.micro
TF_VAR_instance_name=devops-server
TF_VAR_environment=development

# ===== Docker Hub Configuration =====
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_token
DOCKER_IMAGE_NAME=your_dockerhub_username/devops-portfolio
DOCKER_IMAGE_TAG=latest

# ===== EC2 SSH Configuration =====
EC2_HOST=your_ec2_public_ip
EC2_USERNAME=ec2-user
EC2_SSH_KEY_PATH=/path/to/your/private/key.pem

# ===== Application Configuration =====
APP_NAME=DevOps Portfolio
APP_ENV=development
APP_DEBUG=true
APP_PORT=80

# ===== GitHub Configuration (Optional) =====
GITHUB_TOKEN=your_github_token
GITHUB_REPO=saishekar555/aws-devops-project

# ===== Monitoring & Logging =====
LOG_LEVEL=info
MONITOR_ENABLED=false

# ===== Security =====
# Generate strong random strings for these values
AES_ENCRYPTION_KEY=your_encryption_key
API_SECRET_KEY=your_secret_key

# ===== Notification Configuration =====
SLACK_WEBHOOK_URL=
EMAIL_NOTIFICATIONS_ENABLED=false

# ===== Additional Settings =====
TERRAFORM_BACKEND_KEY=aws-devops-project/terraform.tfstate
TERRAFORM_STATE_LOCK=true
